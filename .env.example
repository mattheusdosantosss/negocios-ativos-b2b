# ============================================================
# HUBSPOT
# ============================================================
# Token da Private App do HubSpot
# Onde pegar: HubSpot > Configurações > Integrações > Private Apps
# Scopes de leitura necessários: crm.objects.deals.read, crm.objects.owners.read
HUBSPOT_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ============================================================
# PIPELINE: FUNIL DE VENDAS B2B
# ============================================================
# ID interno da pipeline (Configurações > Negócios > Pipelines).
# "default" = "Funil de Vendas B2B" nesse portal.
HUBSPOT_PIPELINE_B2B=default

# As 7 etapas consideradas "negócio ativo" (Conexão, Reunião agendada /
# Qualificado, Aguardando Envio de Proposta, Proposta enviada, Em negociação,
# Negociação avançada, Resting) estão fixas em lib/hubspot.ts (STAGES),
# porque os rótulos são específicos desse funil e raramente mudam.
