# ============================================================
# HUBSPOT
# ============================================================
# Token da Private App do HubSpot
# Onde pegar: HubSpot > Configurações > Integrações > Private Apps
# Scopes de leitura necessários: crm.objects.deals.read, crm.objects.owners.read
HUBSPOT_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ============================================================
# PIPELINES (por segmento)
# ============================================================
# IDs internos das pipelines (Configurações > Negócios > Pipelines).
# O painel tem duas abas: B2B e B2C, cada uma numa pipeline distinta.
# "default" = "Funil de Vendas B2B"; "725182862" = "Funil de Vendas B2C".
HUBSPOT_PIPELINE_B2B=default
HUBSPOT_PIPELINE_B2C=725182862

# As etapas ativas, de temperatura, de ganho, de checkout e o roster de cada
# segmento estão fixos em lib/segments.ts (SEGMENTS), porque os rótulos são
# específicos de cada funil e raramente mudam.
